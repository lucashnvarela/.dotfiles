set nocompatible

" allow hidden buffers
set hidden

" enable undo history
set undofile
set undodir=$HOME/.vim/undodir

" use system clipboard
set clipboard=unnamed

syntax on
set smartindent
set nowrap

set expandtab
set tabstop=2
set shiftwidth=2

let mapleader = "\\"

set relativenumber

" keep 8 lines above/below cursor
set scrolloff=8

" show cursor position
set ruler